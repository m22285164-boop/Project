[Unit]
Description=IoT web dashboard (Flask)
After=network.target

[Service]
Type=simple
User=pi
Group=www-data
WorkingDirectory=/opt/iot_device_full/web
Environment=IOT_DB_PATH=/opt/iot_device_full/data/device.db
Environment=PYTHONUNBUFFERED=1
ExecStart=/usr/bin/python3 -m flask --app app run --host 0.0.0.0 --port 8080
Restart=on-failure
RestartSec=3
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
